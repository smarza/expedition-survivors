  m_Script: {fileID: 11500000, guid: a8db991118124b87989e4599c4f07101, type: 3}
  m_Name: ProductionContent
  m_EditorClassIdentifier: Assembly-CSharp::ProjectExpedition.ProductionContentDatabase
  characters:
  - id: ravenbound.haldor
    displayName: Haldor Stormborn
    tribe: Ravenbound Vikings
    role: Expedition Leader
    description: A relentless Viking shield-bearer who turns every fallen enemy into another verse of his saga.
    color: {r: 0.29, g: 0.65, b: 0.82, a: 1}
    maxHealth: 150
    moveSpeed: 4.45
    armor: 2
    ultimateName: Ravenstorm
    ultimateDescription: Haldor becomes briefly untouchable and calls a devastating storm of frost axes and ravens around him.
    ultimateCooldown: 60
    ultimateDamage: 145
    ultimateRadius: 6.8
    starterWeaponIds:
    - weapon.frost_axe
    - weapon.raven_guard
  - id: ravenbound.eira
    displayName: Eira Raven-Sworn
    tribe: Ravenbound Vikings
    role: Storm Scout
    description: A swift pathfinder whose ravens mark openings before the enemy realizes it has been surrounded.
    lockedPreviewLine: A Ravenbound pathfinder whose ravens find openings before the enemy realizes it has been surrounded.
    color: {r: 0.88, g: 0.52, b: 0.24, a: 1}
    maxHealth: 122
    moveSpeed: 5.05
    armor: 0.5
    ultimateName: Murder of Ravens
    ultimateDescription: Eira releases a focused murder of ravens that tears through every nearby enemy.
    ultimateCooldown: 52
    ultimateDamage: 112
    ultimateRadius: 5.8
    starterWeaponIds:
    - weapon.frost_axe
    - weapon.raven_guard
  - id: oathbound.sylva
    displayName: Sylva Reedwalker
    tribe: Oathbound Grove
    role: Canopy Warden
    description: An oathbound grove warden who binds thorn and canopy magic — fictional woodland culture, not any real people.
    lockedPreviewLine: An Oathbound grove warden — thorn and canopy magic still waiting to be revealed.
    color: {r: 0.38, g: 0.78, b: 0.42, a: 1}
    maxHealth: 128
    moveSpeed: 4.85
    armor: 1
    ultimateName: Verdant Tempest
    ultimateDescription: Sylva becomes briefly untouchable and unleashes an expanding thorn ring through nearby enemies.
    ultimateCooldown: 54
    ultimateDamage: 118
    ultimateRadius: 6.2
    starterWeaponIds:
    - weapon.grove_thorn_lash
    - weapon.canopy_vortex
  - id: ironway.mara
    displayName: Captain Mara Voss
    tribe: Ironway Expedition Corps
    role: Field Captain
    description: A modern expedition corps captain who marks targets with signal gear and keeps the squad alive in the field.
    lockedPreviewLine: An Ironway field captain — battlefield tactics and squad support still to be discovered.
    color: {r: 0.62, g: 0.68, b: 0.78, a: 1}
    maxHealth: 135
    moveSpeed: 4.65
    armor: 1.5
    ultimateName: Orbital Barrage
    ultimateDescription: Mara becomes briefly untouchable and calls a concentrated strike zone onto the nearest threat cluster.
    ultimateCooldown: 58
    ultimateDamage: 132
    ultimateRadius: 6.5
    starterWeaponIds:
    - weapon.signal_flare
    - weapon.supply_pulse
  maps:
  - id: frostbound.scout
    displayName: The Frostbound Shore
    region: Jotunn Coast
    description: A shorter expedition used to learn the shore, complete a build and confront its Jotunn guardian.
    durationLabel: SCOUT EXPEDITION — 5 MIN
    duration: 300
    bossSpawnTime: 240
    baseSpawnInterval: 0.86
    minimumSpawnInterval: 0.24
    difficultyRamp: 46
    groundColor: {r: 0.075, g: 0.13, b: 0.16, a: 1}
    weaponSlots: 4
    gearSlots: 4
    requiredKillObjective: 150
    optionalShardObjective: 5
    extractionDuration: 15
    extractionBeaconX: 0
    extractionBeaconY: 14
  - id: frostbound.saga
    displayName: 'The Frostbound Shore: Long Night'
    region: Jotunn Coast
    description: The full twelve-minute route. Denser phases, stronger elites and a late Jotunn confrontation.
    lockedPreviewLine: The full Frostbound Shore route — denser phases and a late Jotunn confrontation still await unlock.
