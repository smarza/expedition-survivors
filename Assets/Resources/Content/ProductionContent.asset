  characters:
  - id: ravenbound.haldor
    displayName: Haldor Stormborn
    tribe: Ravenbound Vikings
    role: Expedition Leader
    description: A relentless Viking shield-bearer who turns every fallen enemy into another verse of his saga.
    color: {r: 0.29, g: 0.65, b: 0.82, a: 1}
    maxHealth: 150
    moveSpeed: 4.45
    armor: 2
    ultimateName: Ravenstorm
    ultimateDescription: Haldor becomes briefly untouchable and calls a devastating storm of frost axes and ravens around him.
    ultimateCooldown: 60
    ultimateDamage: 145
    ultimateRadius: 6.8
    starterWeaponIds:
    - weapon.frost_axe
    - weapon.raven_guard
  - id: ravenbound.eira
    displayName: Eira Raven-Sworn
    tribe: Ravenbound Vikings
    role: Storm Scout
    description: A swift pathfinder whose ravens mark openings before the enemy realizes it has been surrounded.
    lockedPreviewLine: A Ravenbound pathfinder whose ravens find openings before the enemy realizes it has been surrounded.
    color: {r: 0.88, g: 0.52, b: 0.24, a: 1}
    maxHealth: 122
    moveSpeed: 5.05
    armor: 0.5
    ultimateName: Murder of Ravens
    ultimateDescription: Eira releases a focused murder of ravens that tears through every nearby enemy.
    ultimateCooldown: 52
    ultimateDamage: 112
    ultimateRadius: 5.8
    starterWeaponIds:
    - weapon.frost_axe
    - weapon.raven_guard
  - id: oathbound.sylva
    displayName: Sylva Reedwalker
    tribe: Oathbound Grove
    role: Canopy Warden
    description: An oathbound grove warden who binds thorn and canopy magic — fictional woodland culture, not any real people.
    lockedPreviewLine: An Oathbound grove warden — thorn and canopy magic still waiting to be revealed.
    color: {r: 0.38, g: 0.78, b: 0.42, a: 1}
    maxHealth: 128
    moveSpeed: 4.85
    armor: 1
    ultimateName: Verdant Tempest
    ultimateDescription: Sylva becomes briefly untouchable and unleashes an expanding thorn ring through nearby enemies.
    ultimateCooldown: 54
    ultimateDamage: 118
    ultimateRadius: 6.2
    starterWeaponIds:
    - weapon.grove_thorn_lash
    - weapon.canopy_vortex
  - id: ironway.mara
    displayName: Captain Mara Voss
    tribe: Ironway Expedition Corps
    role: Field Captain
    description: A modern expedition corps captain who marks targets with signal gear and keeps the squad alive in the field.
    lockedPreviewLine: An Ironway field captain — battlefield tactics and squad support still to be discovered.
    color: {r: 0.62, g: 0.68, b: 0.78, a: 1}
    maxHealth: 135
    moveSpeed: 4.65
    armor: 1.5
    ultimateName: Orbital Barrage
    ultimateDescription: Mara becomes briefly untouchable and calls a concentrated strike zone onto the nearest threat cluster.
    ultimateCooldown: 58
    ultimateDamage: 132
    ultimateRadius: 6.5
    starterWeaponIds:
    - weapon.signal_flare
    - weapon.supply_pulse
  - id: oathbound.bren
    displayName: Bren Oakhart
    tribe: Oathbound Grove
    role: Root Binder
    description: An oathbound rootbinder who anchors allies with living bark and slow, punishing grove magic.
    lockedPreviewLine: An Oathbound rootbinder — living bark and grove magic still waiting to be revealed.
    color: {r: 0.32, g: 0.62, b: 0.38, a: 1}
    maxHealth: 132
    moveSpeed: 4.55
    armor: 1.25
    ultimateName: Living Bulwark
    ultimateDescription: Bren becomes briefly untouchable and erupts a ring of roots that slows nearby enemies.
    ultimateCooldown: 56
    ultimateDamage: 108
    ultimateRadius: 5.8
    starterWeaponIds:
    - weapon.driftwood_staff
    - weapon.oath_ring
  - id: ironway.rex
    displayName: Rex Calder
    tribe: Ironway Expedition Corps
    role: Breacher
    description: An Ironway demolitions specialist who breaks enemy lines with beacons, charges and heavy knockback.
    lockedPreviewLine: An Ironway breacher — demolitions and frontline pressure still to be discovered.
    color: {r: 0.72, g: 0.58, b: 0.42, a: 1}
    maxHealth: 142
    moveSpeed: 4.4
    armor: 2
    ultimateName: Breaching Charge
    ultimateDescription: Rex becomes briefly untouchable and fires a breaching line through the nearest threat cluster.
    ultimateCooldown: 55
    ultimateDamage: 128
    ultimateRadius: 5.5
    starterWeaponIds:
    - weapon.iron_beacon
    - weapon.tide_caller
